# ── LLM provider ─────────────────────────────────────────────────────────────
# Set one block. Anthropic is used by default if ANTHROPIC_API_KEY is present;
# otherwise falls back to OpenAI/compatible if OPENAI_API_KEY or OPENAI_BASE_URL
# is set. Override auto-detection with LLM_PROVIDER.
#
# LLM_PROVIDER=anthropic   # anthropic | openai | ollama | groq | together | lm_studio

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local, no key needed)
# LLM_PROVIDER=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2

# Groq
# LLM_PROVIDER=groq
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-70b-versatile

# Together AI
# LLM_PROVIDER=together
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_MODEL=meta-llama/Llama-3.2-90B-Vision-Instruct-Turbo

# ── Optional read-only HomesToCompare listing connector ───────────────────────
H2C_BASE_URL=https://homestocompare.com
H2C_READ_KEY=
H2C_SERVICE_KEY=

# ── Optional local CSV listing connector ──────────────────────────────────────
# LISTINGS_CSV_PATH=/path/to/listings.csv
TRACE_OUTPUT_DIR=.traces
